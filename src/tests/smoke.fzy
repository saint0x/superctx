test "det_boot_and_health" {
    model.preflight() runtime.boot() let payload = runtime.health_json() if payload == "" {
        checkpoint()
    }
}
test "det_memory_roundtrip" {
    runtime.boot() let created = services.brain.remember("workspace", "fact", "planner uses scoped memory", 8, 9, 1, "persistent", "test", "workspace", "test-session") let created_parsed = model.types.parse_doc(created) let memory_id = model.types.memory_id(created_parsed) if memory_id == "" {
        checkpoint()
    }
    let pinned = services.brain.set_pin(memory_id, "true") if model.types.memory_pinned(model.types.parse_doc(pinned)) != "true" {
        checkpoint()
    }
    let frame = runtime.ask("test-session", "workspace", "inspect the repo with local file tools and cite exact repo paths") let parsed = model.types.parse_doc(frame) if model.types.frame_user_request(parsed) == "" {
        checkpoint()
    }
    if str.contains(frame, "\"task_mode\":\"local_inspect\"") == 0 {
        checkpoint()
    }
    if str.contains(frame, "\"must_cite_paths\":\"true\"") == 0 {
        checkpoint()
    }
}
test "det_snapshot_restore" {
    runtime.boot() discard services.brain.remember("global", "fact", "user prefers deterministic traces", 7, 8, 0, "persistent", "test", "workspace", "snap-session") let snapshot = services.brain.snapshot() let snapshot_id = model.types.snapshot_id(model.types.parse_doc(snapshot)) let restored = services.brain.restore(snapshot_id) if model.types.str_field(model.types.parse_doc(restored), "status") != "ok" {
        checkpoint()
    }
}
test "det_deterministic_completion" {
    runtime.boot() let result = runtime.complete("adapter-session", "workspace", "summarize the current request") if str.contains(result, "\"adapter\":\"DeterministicAdapter\"") == 0 {
        checkpoint()
    }
    if str.contains(result, "\"status\":\"ok\"") == 0 {
        checkpoint()
    }
}
test "det_exact_validation" {
    runtime.boot() let result = runtime.complete("exact-session", "workspace", "give the exact numeric answer for 183 * 27") if str.contains(result, "\"status\":\"ok\"") == 0 {
        checkpoint()
    }
    if str.contains(result, "\"content\":\"4941\"") == 0 {
        checkpoint()
    }
}
