use core.fs;
use core.http;
use core.storage;
use core.log;
use core.time;
use core.process;
use core.term;
mod api;
mod model;
mod services;
mod runtime;
mod cli;
mod tests;
mod util;
fn main() -> i32 {
    model.preflight();
    runtime.boot();
    cli.boot();
    api.touch();
    let cmd = process.argv_or(1, "help");
    if cmd == "help" {
        return cli.print_help()
    }
    if cmd == "--help" {
        return cli.print_help()
    }
    return cli.commands.dispatch()
}
