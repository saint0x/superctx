use core.log;
use core.process;

mod api;
mod model;
mod services;
mod runtime;
mod cli;
mod tests;
mod util;

fn boot_runtime() -> i32 {
    discard model.preflight();
    discard runtime.boot();
    discard cli.boot();
    discard api.touch();
    return 0;
}

fn main() -> i32 {
    discard boot_runtime();
    let command = process.argv_or(1, "help");
    return cli.run(command);
}
