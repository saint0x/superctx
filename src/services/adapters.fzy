fn schema_string_json() -> str {
    return util.json_obj1("type", json.str("string"))
}
fn schema_object_json() -> str {
    let schema = map.new() discard map.set(schema, "type", json.str("object")) discard map.set(schema, "properties", json.raw("{}")) return json.object(schema)
}
fn list_json() -> str {
    let items = list.new() discard list.push(items, json.raw(model.types.adapter_json("OpenAIAdapter", "openai", "https", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("AnthropicAdapter", "anthropic", "https", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("GeminiAdapter", "gemini", "https", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("DeepSeekAdapter", "deepseek", "https", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("OllamaAdapter", "ollama", "local", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("LlamaCppAdapter", "llama.cpp", "local", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("MLXAdapter", "mlx", "local", "planned"))) discard list.push(items, json.raw(model.types.adapter_json("VLLMAdapter", "vllm", "https", "planned"))) return json.array(items)
}
fn tool_schemas_json() -> str {
    let items = list.new() discard list.push(items, json.raw(model.types.tool_schema_json("brain.query", "Query durable memory across scopes.", schema_object_json()))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.remember", "Allocate a new memory object.", schema_object_json()))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.update", "Append or replace memory content.", schema_object_json()))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.pin", "Pin a memory object into hot context.", util.json_obj1("memory_id", json.raw(schema_string_json()))))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.unpin", "Remove a pin from memory.", util.json_obj1("memory_id", json.raw(schema_string_json()))))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.promote", "Raise importance and durability.", util.json_obj1("memory_id", json.raw(schema_string_json()))))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.demote", "Lower importance.", util.json_obj1("memory_id", json.raw(schema_string_json()))))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.compact", "Summarize selected memory into a new object.", schema_object_json()))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.forget", "Mark a memory object forgotten.", util.json_obj1("memory_id", json.raw(schema_string_json()))))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.snapshot", "Capture the current brain state.", schema_object_json()))) discard list.push(items, json.raw(model.types.tool_schema_json("brain.restore", "Restore a prior brain snapshot.", schema_object_json()))) return json.array(items)
}
