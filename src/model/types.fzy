    let payload = map.new() discard map.set(payload, "session_id", json.str(session_id)) discard map.set(payload, "workspace_id", json.str(workspace_id)) discard map.set(payload, "goal", json.str(goal)) discard map.set(payload, "request", json.str(request)) discard map.set(payload, "state", json.str(state)) discard map.set(payload, "frame_path", json.str(frame_path)) discard map.set(payload, "updated_at", json.str(updated_at)) return json.object(payload)
}
fn string_list_json(a: str, b: str, c: str, d: str) -> str {
    let items = list.new() if a != "" {
        discard list.push(items, json.str(a))
    }
    if b != "" {
        discard list.push(items, json.str(b))
    }
    if c != "" {
        discard list.push(items, json.str(c))
    }
    if d != "" {
        discard list.push(items, json.str(d))
    }
    return json.array(items)
}
fn protocol_policy_json(task_mode: str, answer_contract: str, grounding_contract: str, must_cite_paths: str, must_obey_tool_outputs: str, max_tool_roundtrips: str, allowed_tool_classes_json: str, blocked_tool_classes_json: str) -> str {
    let payload = map.new() discard map.set(payload, "task_mode", json.str(task_mode)) discard map.set(payload, "answer_contract", json.str(answer_contract)) discard map.set(payload, "grounding_contract", json.str(grounding_contract)) discard map.set(payload, "must_cite_paths", json.str(must_cite_paths)) discard map.set(payload, "must_obey_tool_outputs", json.str(must_obey_tool_outputs)) discard map.set(payload, "max_tool_roundtrips", json.str(max_tool_roundtrips)) discard map.set(payload, "allowed_tool_classes", json.raw(allowed_tool_classes_json)) discard map.set(payload, "blocked_tool_classes", json.raw(blocked_tool_classes_json)) return json.object(payload)
}
