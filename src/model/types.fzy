    let payload = map.new() discard map.set(payload, "id", json.str(id)) discard map.set(payload, "from_id", json.str(from_id)) discard map.set(payload, "relation", json.str(relation)) discard map.set(payload, "to_id", json.str(to_id)) discard map.set(payload, "created_at", json.str(created_at)) return json.object(payload)
