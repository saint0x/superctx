fn memory_json(id: str, scope: str, kind: str, content: str, importance: str, confidence: str, pinned: str, ttl: str, provenance: str, workspace_id: str, session_id: str, created_at: str, updated_at: str, last_accessed_at: str, status: str) -> str {
    let payload = map.new() discard map.set(payload, "id", json.str(id)) discard map.set(payload, "scope", json.str(scope)) discard map.set(payload, "kind", json.str(kind)) discard map.set(payload, "content", json.str(content)) discard map.set(payload, "importance", json.str(importance)) discard map.set(payload, "confidence", json.str(confidence)) discard map.set(payload, "pinned", json.str(pinned)) discard map.set(payload, "ttl", json.str(ttl)) discard map.set(payload, "provenance", json.str(provenance)) discard map.set(payload, "workspace_id", json.str(workspace_id)) discard map.set(payload, "session_id", json.str(session_id)) discard map.set(payload, "created_at", json.str(created_at)) discard map.set(payload, "updated_at", json.str(updated_at)) discard map.set(payload, "last_accessed_at", json.str(last_accessed_at)) discard map.set(payload, "status", json.str(status)) return json.object(payload)
}
